# AutoFlow 环境变量配置示例
# 复制此文件为 .env 并填入真实的 API Key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Redis (可选, 默认 redis://localhost:6379)
REDIS_URL=redis://localhost:6379
# Wanqing OpenAI-compatible endpoint (used by config/agents/wanqing-smoke-test.yaml)
# WQ_API_KEY=replace-with-your-key

# MiniMax M3 native endpoint (used by config/agents/minimax-m3-smoke-test.yaml)
# MINIMAX_API_KEY=replace-with-your-key
